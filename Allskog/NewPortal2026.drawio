        <UserObject label="&lt;p style=&quot;margin:0in;font-family:Calibri;font-size:11.0pt&quot; lang=&quot;en-US&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;Nytt domene&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:Calibri;font-size:11.0pt&quot; lang=&quot;en-US&quot;&gt;medlem.allskog.no&lt;/p&gt;&lt;br&gt;&lt;p style=&quot;margin:0in;font-family:Calibri;font-size:11.0pt&quot; lang=&quot;en-US&quot;&gt;&lt;span style=&quot;font-weight: bold; font-size: 11pt; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Azure&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:Calibri;font-size:11.0pt&quot; lang=&quot;en-US&quot;&gt;Cartagenas forslag&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:Calibri;font-size:11.0pt&quot; lang=&quot;en-US&quot;&gt;&lt;span style=&quot;font-weight:bold&quot;&gt;&lt;br&gt;Innlogging&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:Calibri;font-size:11.0pt&quot; lang=&quot;en-US&quot;&gt;Login uten passord&lt;br&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:Calibri;font-size:11.0pt&quot; lang=&quot;en-US&quot;&gt;&lt;span style=&quot;font-weight: bold; font-size: 11pt; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Dataverse&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:Calibri;font-size:11.0pt&quot; lang=&quot;en-US&quot;&gt;Ikke lengre nyheter.&lt;br&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:Calibri;font-size:11.0pt&quot; lang=&quot;en-US&quot;&gt;Kun&amp;nbsp;kalender. Bruker aktiviteter-tabell?&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:Calibri;font-size:11.0pt&quot; lang=&quot;en-US&quot;&gt;Ønskelig at vi gjør det eller ønsker dere å gjøre det selv?&lt;/p&gt;&lt;p style=&quot;margin:0in;font-family:Calibri;font-size:11.0pt&quot; lang=&quot;en-US&quot;&gt;Vi kan presentere et forslag til oppsett før vi gjennomfører det&lt;/p&gt